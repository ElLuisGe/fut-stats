<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>Jugadores - Futbol Stats</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        /* Estilos para mejorar la legibilidad en móviles */
        .table-responsive {
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }
        .text-truncate {
            max-width: 150px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        @media (max-width: 640px) {
            .text-truncate {
                max-width: 100px;
            }
        }
    </style>
</head>
<body class="bg-gradient-to-br from-green-50 to-blue-50 min-h-screen">
    <!-- Aquí va la barra de navegación que actualizamos arriba -->

    <div class="container mx-auto px-3 sm:px-4 md:px-6 py-4 sm:py-6 md:py-8">
        <!-- Header con título y botón -->
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
            <h2 class="text-2xl sm:text-3xl font-bold text-gray-800 flex items-center">
                <i class="fas fa-users text-green-600 mr-3"></i>
                Gestión de Jugadores
            </h2>
            <button onclick="abrirModal('nuevo')" class="w-full sm:w-auto bg-green-600 hover:bg-green-700 text-white px-4 sm:px-6 py-3 rounded-lg font-semibold transition flex items-center justify-center shadow-md">
                <i class="fas fa-plus mr-2"></i>
                Nuevo Jugador
            </button>
        </div>

        <!-- Tabla de jugadores mejorada -->
        <div class="bg-white rounded-xl shadow-lg overflow-hidden">
            <div class="table-responsive">
                <table class="w-full min-w-[800px] md:min-w-full">
                    <thead class="bg-gradient-to-r from-gray-50 to-gray-100">
                        <tr>
                            <th class="px-2 sm:px-4 py-3 text-left text-xs font-medium text-gray-600 uppercase tracking-wider">Jugador</th>
                            <th class="px-2 sm:px-4 py-3 text-left text-xs font-medium text-gray-600 uppercase tracking-wider">Equipo</th>
                            <th class="px-2 sm:px-4 py-3 text-center text-xs font-medium text-gray-600 uppercase tracking-wider">G</th>
                            <th class="px-2 sm:px-4 py-3 text-center text-xs font-medium text-gray-600 uppercase tracking-wider">A</th>
                            <th class="px-2 sm:px-4 py-3 text-center text-xs font-medium text-gray-600 uppercase tracking-wider">TA</th>
                            <th class="px-2 sm:px-4 py-3 text-center text-xs font-medium text-gray-600 uppercase tracking-wider">TR</th>
                            <th class="px-2 sm:px-4 py-3 text-center text-xs font-medium text-gray-600 uppercase tracking-wider">PJ</th>
                            <th class="px-2 sm:px-4 py-3 text-center text-xs font-medium text-gray-600 uppercase tracking-wider">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200">
                        <% if (jugadores && jugadores.length > 0) { %>
                            <% jugadores.forEach(jugador => { %>
                            <tr class="hover:bg-gray-50 transition">
                                <td class="px-2 sm:px-4 py-3">
                                    <div class="flex items-center">
                                        <div class="w-8 h-8 bg-green-100 rounded-full flex items-center justify-center text-green-600 font-bold mr-2">
                                            <%= jugador.nombre.charAt(0) %>
                                        </div>
                                        <div>
                                            <div class="font-medium text-gray-900 text-sm sm:text-base"><%= jugador.nombre %></div>
                                            <div class="text-xs text-gray-500"><%= jugador.posicion || 'Sin posición' %> • #<%= jugador.numero || '?' %></div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-2 sm:px-4 py-3">
                                    <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium" 
                                          style="background-color: <%= jugador.equipo_color || '#10b981' %>20; color: <%= jugador.equipo_color || '#10b981' %>">
                                        <span class="w-2 h-2 rounded-full mr-1" style="background-color: <%= jugador.equipo_color || '#10b981' %>"></span>
                                        <%= jugador.equipo_nombre || 'Sin equipo' %>
                                    </span>
                                </td>
                                <td class="px-2 sm:px-4 py-3 text-center">
                                    <span class="text-lg font-bold text-green-600"><%= jugador.total_goles || 0 %></span>
                                </td>
                                <td class="px-2 sm:px-4 py-3 text-center">
                                    <span class="text-lg font-bold text-blue-600"><%= jugador.total_asistencias || 0 %></span>
                                </td>
                                <td class="px-2 sm:px-4 py-3 text-center">
                                    <span class="text-yellow-600"><%= jugador.total_amarillas || 0 %></span>
                                </td>
                                <td class="px-2 sm:px-4 py-3 text-center">
                                    <span class="text-red-600"><%= jugador.total_rojas || 0 %></span>
                                </td>
                                <td class="px-2 sm:px-4 py-3 text-center">
                                    <span class="font-medium"><%= jugador.partidos_jugados || 0 %></span>
                                </td>
                                <td class="px-2 sm:px-4 py-3">
                                    <div class="flex items-center justify-center space-x-2">
                                        <button onclick="registrarEvento(<%= jugador.id %>, 'gol')" class="text-green-600 hover:text-green-800 p-1" title="Registrar gol">
                                            <i class="fas fa-futbol"></i>
                                        </button>
                                        <button onclick="registrarEvento(<%= jugador.id %>, 'asistencia')" class="text-blue-600 hover:text-blue-800 p-1" title="Registrar asistencia">
                                            <i class="fas fa-hands-helping"></i>
                                        </button>
                                        <button onclick="registrarEvento(<%= jugador.id %>, 'amarilla')" class="text-yellow-500 hover:text-yellow-700 p-1" title="Tarjeta amarilla">
                                            <i class="fas fa-square"></i>
                                        </button>
                                        <button onclick="registrarEvento(<%= jugador.id %>, 'roja')" class="text-red-500 hover:text-red-700 p-1" title="Tarjeta roja">
                                            <i class="fas fa-square"></i>
                                        </button>
                                        <button onclick="editarJugador(<%= jugador.id %>)" class="text-blue-500 hover:text-blue-700 p-1" title="Editar">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button onclick="eliminarJugador(<%= jugador.id %>)" class="text-red-500 hover:text-red-700 p-1" title="Eliminar">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="8" class="px-4 py-8 text-center text-gray-500">
                                    <i class="fas fa-users text-4xl mb-3 text-gray-400"></i>
                                    <p>No hay jugadores registrados</p>
                                    <button onclick="abrirModal('nuevo')" class="mt-3 text-green-600 hover:text-green-700 font-medium">
                                        + Agregar primer jugador
                                    </button>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Modal para nuevo/editar jugador -->
    <div id="modalJugador" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50 p-4">
        <div class="bg-white rounded-xl p-4 sm:p-6 max-w-md w-full max-h-[90vh] overflow-y-auto">
            <h3 id="modalTitulo" class="text-xl sm:text-2xl font-bold mb-4 sm:mb-6">Agregar Nuevo Jugador</h3>
            <form id="formJugador">
                <input type="hidden" id="jugador_id">
                <div class="space-y-3 sm:space-y-4">
                    <div>
                        <label class="block text-gray-700 text-sm sm:text-base mb-1 sm:mb-2">Nombre del jugador *</label>
                        <input type="text" id="nombre" required class="w-full px-3 sm:px-4 py-2 border rounded-lg focus:outline-none focus:border-green-500 text-sm sm:text-base">
                    </div>
                    <div>
                        <label class="block text-gray-700 text-sm sm:text-base mb-1 sm:mb-2">Equipo *</label>
                        <select id="equipo_id" required class="w-full px-3 sm:px-4 py-2 border rounded-lg focus:outline-none focus:border-green-500 text-sm sm:text-base">
                            <option value="">Seleccionar equipo</option>
                            <% equipos.forEach(equipo => { %>
                            <option value="<%= equipo.id %>"><%= equipo.nombre %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div>
                        <label class="block text-gray-700 text-sm sm:text-base mb-1 sm:mb-2">Posición</label>
                        <select id="posicion" class="w-full px-3 sm:px-4 py-2 border rounded-lg focus:outline-none focus:border-green-500 text-sm sm:text-base">
                            <option value="">Seleccionar posición</option>
                            <option value="Portero">Portero</option>
                            <option value="Defensa">Defensa</option>
                            <option value="Mediocampista">Mediocampista</option>
                            <option value="Delantero">Delantero</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-gray-700 text-sm sm:text-base mb-1 sm:mb-2">Número</label>
                        <input type="number" id="numero" min="1" max="99" class="w-full px-3 sm:px-4 py-2 border rounded-lg focus:outline-none focus:border-green-500 text-sm sm:text-base">
                    </div>
                </div>
                <div class="flex flex-col sm:flex-row justify-end space-y-2 sm:space-y-0 sm:space-x-3 mt-4 sm:mt-6">
                    <button type="button" onclick="cerrarModal()" class="w-full sm:w-auto px-4 sm:px-6 py-2 border rounded-lg hover:bg-gray-100 text-sm sm:text-base">
                        Cancelar
                    </button>
                    <button type="submit" class="w-full sm:w-auto px-4 sm:px-6 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 text-sm sm:text-base">
                        Guardar
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Modal para registrar evento -->
    <div id="modalEvento" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50 p-4">
        <div class="bg-white rounded-xl p-4 sm:p-6 max-w-md w-full">
            <h3 class="text-xl sm:text-2xl font-bold mb-4 sm:mb-6">Registrar Evento</h3>
            <form id="formEvento">
                <input type="hidden" id="evento_jugador_id">
                <input type="hidden" id="evento_tipo">
                <div class="space-y-3 sm:space-y-4">
                    <div>
                        <label class="block text-gray-700 text-sm sm:text-base mb-1 sm:mb-2">Partido</label>
                        <select id="evento_partido_id" required class="w-full px-3 sm:px-4 py-2 border rounded-lg focus:outline-none focus:border-green-500 text-sm sm:text-base">
                            <option value="">Seleccionar partido</option>
                            <!-- Aquí se cargarían los partidos -->
                        </select>
                    </div>
                    <div>
                        <label class="block text-gray-700 text-sm sm:text-base mb-1 sm:mb-2">Minuto</label>
                        <input type="number" id="evento_minuto" min="0" max="120" class="w-full px-3 sm:px-4 py-2 border rounded-lg focus:outline-none focus:border-green-500 text-sm sm:text-base">
                    </div>
                </div>
                <div class="flex flex-col sm:flex-row justify-end space-y-2 sm:space-y-0 sm:space-x-3 mt-4 sm:mt-6">
                    <button type="button" onclick="cerrarModalEvento()" class="w-full sm:w-auto px-4 sm:px-6 py-2 border rounded-lg hover:bg-gray-100 text-sm sm:text-base">
                        Cancelar
                    </button>
                    <button type="submit" class="w-full sm:w-auto px-4 sm:px-6 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 text-sm sm:text-base">
                        Registrar
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        let jugadorEditando = null;

        function abrirModal(modo, jugadorId = null) {
            if (modo === 'editar' && jugadorId) {
                document.getElementById('modalTitulo').textContent = 'Editar Jugador';
                cargarJugador(jugadorId);
            } else {
                document.getElementById('modalTitulo').textContent = 'Agregar Nuevo Jugador';
                document.getElementById('formJugador').reset();
                document.getElementById('jugador_id').value = '';
            }
            document.getElementById('modalJugador').style.display = 'flex';
        }

        async function cargarJugador(id) {
            try {
                const response = await fetch('/api/jugadores/' + id);
                const jugador = await response.json();
                
                document.getElementById('jugador_id').value = jugador.id;
                document.getElementById('nombre').value = jugador.nombre;
                document.getElementById('equipo_id').value = jugador.equipo_id;
                document.getElementById('posicion').value = jugador.posicion || '';
                document.getElementById('numero').value = jugador.numero || '';
            } catch (error) {
                alert('Error al cargar jugador');
            }
        }

        function cerrarModal() {
            document.getElementById('modalJugador').style.display = 'none';
        }

        document.getElementById('formJugador').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const jugador = {
                nombre: document.getElementById('nombre').value,
                equipo_id: document.getElementById('equipo_id').value,
                posicion: document.getElementById('posicion').value,
                numero: document.getElementById('numero').value
            };

            const id = document.getElementById('jugador_id').value;
            const url = id ? '/api/jugadores/' + id : '/api/jugadores';
            const method = id ? 'PUT' : 'POST';

            try {
                const response = await fetch(url, {
                    method: method,
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(jugador)
                });

                const data = await response.json();
                
                if (data.success) {
                    alert(id ? 'Jugador actualizado' : 'Jugador agregado');
                    location.reload();
                } else {
                    alert('Error: ' + data.message);
                }
            } catch (error) {
                alert('Error al guardar jugador');
            }
        });

        function registrarEvento(jugadorId, tipo) {
            document.getElementById('evento_jugador_id').value = jugadorId;
            document.getElementById('evento_tipo').value = tipo;
            
            let titulo = '';
            switch(tipo) {
                case 'gol': titulo = '⚽ Registrar Gol'; break;
                case 'asistencia': titulo = '🎯 Registrar Asistencia'; break;
                case 'amarilla': titulo = '🟨 Registrar Tarjeta Amarilla'; break;
                case 'roja': titulo = '🟥 Registrar Tarjeta Roja'; break;
            }
            document.querySelector('#modalEvento h3').textContent = titulo;
            
            document.getElementById('modalEvento').style.display = 'flex';
        }

        function cerrarModalEvento() {
            document.getElementById('modalEvento').style.display = 'none';
        }

        document.getElementById('formEvento').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const evento = {
                jugador_id: document.getElementById('evento_jugador_id').value,
                partido_id: document.getElementById('evento_partido_id').value,
                tipo: document.getElementById('evento_tipo').value,
                minuto: document.getElementById('evento_minuto').value
            };

            try {
                const response = await fetch('/api/eventos', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(evento)
                });

                const data = await response.json();
                
                if (data.success) {
                    alert('Evento registrado correctamente');
                    location.reload();
                } else {
                    alert('Error: ' + data.message);
                }
            } catch (error) {
                alert('Error al registrar evento');
            }
        });

        async function eliminarJugador(id) {
            if (confirm('¿Estás seguro de eliminar este jugador?')) {
                try {
                    const response = await fetch('/api/jugadores/' + id, {
                        method: 'DELETE'
                    });
                    
                    const data = await response.json();
                    
                    if (data.success) {
                        alert('Jugador eliminado');
                        location.reload();
                    } else {
                        alert('Error: ' + data.message);
                    }
                } catch (error) {
                    alert('Error al eliminar jugador');
                }
            }
        }

        function editarJugador(id) {
            abrirModal('editar', id);
        }

        // Cargar partidos para el selector
        async function cargarPartidos() {
            try {
                const response = await fetch('/api/partidos');
                // Esto es simplificado, necesitarías un endpoint para obtener partidos
            } catch (error) {
                console.error('Error al cargar partidos');
            }
        }
    </script>
</body>
</html>